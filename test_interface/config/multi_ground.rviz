    Tree Height: 840
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /Publish Point1
      - /2D Nav Goal1
    Name: Tool Properties
    Splitter Ratio: 0.5799999833106995
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: ExploredCloud
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
