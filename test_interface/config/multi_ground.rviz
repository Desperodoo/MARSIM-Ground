Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /GlobalCloud1
        - /Quad01
        - /Quad01/ExploredCloud1
        - /Quad11
        - /Quad11/ExploredCloud1
        - /Quad21
        - /Quad21/ExploredCloud1
